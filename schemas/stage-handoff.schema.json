{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ianyoufather-2007/amazon-pm-integrated-agent/schemas/stage-handoff.schema.json",
  "title": "Amazon PM Stage Handoff",
  "description": "A portable contract for transferring evidence, stage boundaries, gaps, and next actions between Amazon product-management workflow stages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "execution",
    "evidence_inventory",
    "stage_gate",
    "handoff"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marketplace",
        "product_direction",
        "language"
      ],
      "properties": {
        "marketplace": {
          "type": "string",
          "minLength": 1
        },
        "product_direction": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "round",
        "current_stage",
        "status"
      ],
      "properties": {
        "route": {
          "enum": [
            "pm_triage",
            "stage_gate"
          ]
        },
        "round": {
          "enum": [
            "pm_triage",
            "round_1",
            "round_2",
            "round_3",
            "delivery"
          ]
        },
        "current_stage": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7
        },
        "status": {
          "enum": [
            "ready",
            "conditional",
            "blocked"
          ]
        }
      }
    },
    "evidence_inventory": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "source_kind",
          "collected_on",
          "confidence",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "source_kind": {
            "enum": [
              "public",
              "synthetic",
              "user_provided",
              "estimated"
            ]
          },
          "collected_on": {
            "type": "string",
            "format": "date"
          },
          "record_count": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "confidence": {
            "enum": [
              "confirmed",
              "estimated",
              "unverified"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "stage_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_outputs",
        "forbidden_outputs",
        "known_facts",
        "signal_reading",
        "risks",
        "data_gaps",
        "decisions_for_meeting"
      ],
      "properties": {
        "allowed_outputs": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "forbidden_outputs": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "known_facts": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "signal_reading": {
          "$ref": "#/$defs/stringArray"
        },
        "risks": {
          "$ref": "#/$defs/stringArray"
        },
        "data_gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "priority",
              "gap",
              "why_it_matters",
              "next_action"
            ],
            "properties": {
              "priority": {
                "enum": [
                  "P0",
                  "P1",
                  "P2"
                ]
              },
              "gap": {
                "type": "string",
                "minLength": 1
              },
              "why_it_matters": {
                "type": "string",
                "minLength": 1
              },
              "next_action": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "decisions_for_meeting": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "next_stage",
        "required_inputs",
        "deliverables",
        "acceptance_checks"
      ],
      "properties": {
        "next_stage": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 7
        },
        "required_inputs": {
          "$ref": "#/$defs/stringArray"
        },
        "deliverables": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "acceptance_checks": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
